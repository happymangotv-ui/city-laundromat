<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-logo">The City <em>Laundry</em></div>
      <p class="footer-desc">{{ business.tagline }} Clean clothes, happy customers — every time.</p>
    </div>
    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        <li><a href="/pickup-delivery.html">Pickup &amp; Delivery</a></li>
        <li><a href="/self-serve.html">Self-Serve</a></li>
        <li><a href="/commercial.html">Commercial</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Contact</h4>
      <ul>
        <li><span>{{ business.full_address }}</span></li>
        <li><a href="tel:{{ business.phone_raw }}">{{ business.phone }}</a></li>
        <li><a href="mailto:{{ business.email }}">{{ business.email }}</a></li>
        <li><span>{{ business.hours }}</span></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2025 {{ business.name }}. All rights reserved.</span>
    <span>{{ business.full_address }}</span>
  </div>
</footer>
