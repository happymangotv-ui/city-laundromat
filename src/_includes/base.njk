<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or business.name }}</title>
  <meta name="description" content="{{ description or business.tagline }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  {%- if schema %}
  <script type="application/ld+json">{{ schema | safe }}</script>
  {%- endif %}
  <style>

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      /* Brand teal */
      --teal:#2d7d6e;
      --teal-dark:#1f5c52;
      --teal-light:#e8f4f2;
      /* Airbnb-style neutrals */
      --ink:#222222;
      --charcoal:#3f3f3f;
      --ash:#6a6a6a;
      --stone:#c1c1c1;
      --hairline:#dddddd;
      --cloud:#f7f7f7;
      --white:#ffffff;
      /* Elevation */
      --shadow-panel:rgba(0,0,0,0.02) 0 0 0 1px,rgba(0,0,0,0.04) 0 2px 6px 0,rgba(0,0,0,0.10) 0 4px 8px 0;
      --shadow-icon:rgba(0,0,0,0.08) 0 4px 12px;
      /* Hero gradient — blue kept per user preference */
      --hero-bg:linear-gradient(135deg,#dce8f0 0%,#c8dce8 50%,#b8d0e0 100%);
      /* Backwards-compat aliases for inline styles in page templates */
      --near-black:#222222;
      --body:#222222;
      --muted:#6a6a6a;
      --green:#2d7d6e;
      --green-deep:#2d7d6e;
      --green-light:#e8f4f2;
      --border:rgba(0,0,0,0.06);
      --border-md:rgba(0,0,0,0.10);
      --gray-200:#dddddd;
      --gray-100:#f7f7f7;
      --shadow:var(--shadow-panel);
      --shadow-btn:rgba(0,0,0,0.06) 0 1px 2px;
      --shadow-hover:var(--shadow-icon);
    }
    html{scroll-behavior:smooth;background:#fff}
    body{font-family:'Inter',system-ui,-apple-system,sans-serif;color:var(--ink);background:var(--white);overflow-x:hidden;font-size:16px;line-height:1.5;font-weight:500}
    h1,h2,h3,h4{font-family:'Inter',system-ui,sans-serif;color:var(--ink);font-weight:700}
    a{text-decoration:none;color:inherit}
    img{display:block}

    /* ── NAV ── */
    nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;height:72px;padding:0 5%;background:rgba(255,255,255,0.97);backdrop-filter:blur(12px);border-bottom:1px solid var(--hairline);gap:1rem}
    .nav-logo{font-size:1.1rem;font-weight:700;color:var(--ink);letter-spacing:-0.3px;text-decoration:none}
    .nav-logo em{font-style:normal;color:var(--teal)}
    .nav-links{display:flex;gap:2rem;list-style:none}
    .nav-links a{font-size:0.875rem;font-weight:500;color:var(--ash);transition:color 0.2s;text-decoration:none}
    .nav-links a:hover,.nav-links a.active{color:var(--ink)}
    .nav-cta{background:var(--teal);color:#fff;padding:10px 22px;border-radius:20px;font-size:0.875rem;font-weight:600;transition:background 0.2s;white-space:nowrap;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
    .nav-cta:hover{background:var(--teal-dark)}
    .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
    .hamburger span{display:block;width:22px;height:2px;background:var(--ink);border-radius:2px;transition:transform 0.3s ease,opacity 0.2s ease}
    .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
    .hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0)}
    .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
    .mobile-menu{display:none;flex-direction:column;position:fixed;top:0;left:0;right:0;bottom:0;background:white;z-index:300;padding:80px 5% 40px}
    .mobile-menu.open{display:flex}
    .mobile-menu a{font-size:1.1rem;font-weight:500;color:var(--ink);padding:16px 0;border-bottom:1px solid var(--hairline);text-decoration:none}
    .mobile-menu a:hover{color:var(--teal)}
    .mobile-menu .close-btn{position:absolute;top:18px;right:5%;font-size:1.5rem;background:none;border:none;cursor:pointer;color:var(--ink);line-height:1}
    .mobile-menu .mobile-cta{margin-top:28px;background:var(--teal);color:#fff;padding:14px;border-radius:20px;text-align:center;font-weight:600;font-size:1rem;text-decoration:none}

    /* ── HERO (blue gradient preserved) ── */
    .hero{min-height:60vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:120px 5% 80px;background:var(--hero-bg);gap:60px}
    .hero-badge{display:inline-flex;align-items:center;gap:6px;background:var(--teal-light);color:var(--teal-dark);padding:5px 14px;border-radius:20px;font-size:0.75rem;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:20px}
    .hero h1{font-size:clamp(2rem,4.5vw,3.6rem);font-weight:700;line-height:1.1;color:var(--ink);margin-bottom:18px;letter-spacing:-1.5px}
    .hero h1 em{font-style:normal;color:var(--teal)}
    .hero p{font-size:1rem;color:var(--ash);line-height:1.65;margin-bottom:32px;max-width:460px;font-weight:500}
    .hero-buttons{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:28px}
    .btn-primary{background:var(--teal);color:#fff;padding:12px 26px;border-radius:20px;font-size:0.875rem;font-weight:600;display:inline-flex;align-items:center;gap:8px;transition:background 0.2s;text-decoration:none;border:none;cursor:pointer}
    .btn-primary:hover{background:var(--teal-dark)}
    .btn-secondary{background:var(--white);color:var(--ink);padding:11px 26px;border-radius:20px;font-size:0.875rem;font-weight:500;border:1.5px solid var(--hairline);display:inline-flex;align-items:center;gap:8px;transition:border-color 0.2s,box-shadow 0.2s;text-decoration:none}
    .btn-secondary:hover{border-color:var(--stone);box-shadow:var(--shadow-icon)}
    .hero-price{display:inline-flex;align-items:center;gap:8px;font-size:0.875rem;color:var(--ash)}
    .hero-price strong{color:var(--teal);font-weight:600}
    .hero-img-col{position:relative}
    .hero-img-wrap{border-radius:20px;overflow:hidden;box-shadow:var(--shadow-panel);aspect-ratio:3/2;width:100%;border:1px solid var(--hairline)}
    .hero-img-wrap img{width:100%;height:100%;object-fit:cover}

    /* ── SECTIONS ── */
    section{padding:80px 6%}
    .section-label{font-size:0.75rem;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:var(--teal);margin-bottom:10px}
    .section-title{font-size:clamp(1.8rem,3vw,2.4rem);font-weight:700;color:var(--ink);line-height:1.1;letter-spacing:-1px;margin-bottom:14px}
    .section-sub{font-size:1rem;color:var(--ash);line-height:1.65;max-width:480px;font-weight:500}
    .section-header{margin-bottom:48px}
    .section-header.center{text-align:center}
    .section-header.center .section-sub{margin:0 auto}
    .section-divider{border-top:1px solid var(--hairline)}

    /* ── PHOTO CARDS (listing-card style) ── */
    .cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px}
    .photo-card{background:var(--white);border-radius:14px;overflow:hidden;transition:box-shadow 0.2s;display:flex;flex-direction:column}
    .photo-card:hover{box-shadow:var(--shadow-panel)}
    .photo-card-img{aspect-ratio:16/9;overflow:hidden;flex-shrink:0;border-radius:14px;border:1px solid var(--hairline)}
    .photo-card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s}
    .photo-card:hover .photo-card-img img{transform:scale(1.04)}
    .photo-card-body{padding:14px 4px;flex:1;display:flex;flex-direction:column}
    .photo-card-body h3{font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:6px;letter-spacing:-0.2px;line-height:1.25}
    .photo-card-body p{font-size:0.875rem;color:var(--ash);line-height:1.6;flex:1;font-weight:500}
    .photo-card-link{display:inline-flex;align-items:center;gap:4px;font-size:0.8rem;font-weight:600;color:var(--teal);margin-top:10px}
    .photo-card-link:hover{color:var(--teal-dark)}

    /* ── PHOTO BANNER ── */
    .photo-banner{position:relative;min-height:420px;display:flex;align-items:center;overflow:hidden}
    .photo-banner-bg{position:absolute;inset:0}
    .photo-banner-bg img{width:100%;height:100%;object-fit:cover}
    .photo-banner-overlay{position:absolute;inset:0;background:rgba(18,28,26,0.72)}
    .photo-banner-content{position:relative;z-index:2;padding:80px 6%;max-width:640px}
    .photo-banner-content .section-label{color:rgba(255,255,255,0.65)}
    .photo-banner-content .section-title{color:#fff;margin-bottom:16px}
    .photo-banner-content p{color:rgba(255,255,255,0.75);font-size:1rem;line-height:1.7;margin-bottom:32px}
    .btn-white{background:#fff;color:var(--ink);padding:12px 26px;border-radius:20px;font-size:0.875rem;font-weight:600;display:inline-flex;align-items:center;gap:8px;transition:opacity 0.2s;text-decoration:none}
    .btn-white:hover{opacity:0.9}

    /* ── STEPS ── */
    .steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;position:relative}
    .steps-grid::before{content:'';position:absolute;top:27px;left:calc(16.6% + 20px);right:calc(16.6% + 20px);height:1px;background:var(--hairline);z-index:0}
    .step{text-align:center;padding:0 28px;position:relative;z-index:1}
    .step-num{width:54px;height:54px;background:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:1rem;font-weight:700;color:#fff}
    .step h3{font-size:1rem;font-weight:600;color:var(--ink);margin-bottom:8px}
    .step p{font-size:0.875rem;color:var(--ash);line-height:1.6;font-weight:500}

    /* ── SPLIT SECTION ── */
    .split{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
    .split.reverse .split-img{order:-1}
    .split-img{border-radius:16px;overflow:hidden;aspect-ratio:4/3;border:1px solid var(--hairline)}
    .split-img img{width:100%;height:100%;object-fit:cover}
    .split-text .section-sub{max-width:none;margin-bottom:28px}
    .check-list{list-style:none;display:flex;flex-direction:column;gap:12px}
    .check-list li{display:flex;align-items:flex-start;gap:10px;font-size:0.9rem;color:var(--ash);line-height:1.6;font-weight:500}
    .check-list li::before{content:'';width:20px;height:20px;border-radius:50%;background:var(--teal-light);border:1.5px solid var(--teal);flex-shrink:0;margin-top:1px;background-image:url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l3 3 5-6' stroke='%232d7d6e' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:center}

    /* ── PRICING CARDS ── */
    .pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:900px;margin:0 auto}
    .pricing-card{background:var(--white);border-radius:14px;padding:28px 24px;border:1px solid var(--hairline);box-shadow:var(--shadow-panel);text-align:center}
    .pricing-card h3{font-size:0.75rem;font-weight:600;margin-bottom:16px;color:var(--ash);text-transform:uppercase;letter-spacing:0.5px}
    .price-num{font-size:2.5rem;font-weight:700;color:var(--teal);line-height:1;letter-spacing:-1.5px}
    .price-unit{font-size:0.85rem;color:var(--ash);font-weight:500;margin-top:4px;margin-bottom:12px}
    .pricing-card p{font-size:0.875rem;color:var(--ash);line-height:1.6;font-weight:500}

    /* ── INFO STRIP ── */
    .info-strip{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--hairline);border-radius:16px;overflow:hidden}
    .info-block{background:var(--white);padding:28px 24px;text-align:center;border-right:1px solid var(--hairline)}
    .info-block:last-child{border-right:none}
    .info-block-icon{width:40px;height:40px;background:var(--teal-light);border-radius:10px;margin:0 auto 12px;display:flex;align-items:center;justify-content:center}
    .info-block-icon svg{width:20px;height:20px;stroke:var(--teal);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
    .info-block .label{font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--stone);margin-bottom:4px}
    .info-block .val{font-size:0.9rem;font-weight:600;color:var(--ink);line-height:1.4}

    /* ── CTA STRIP (teal band) ── */
    .cta-strip{background:var(--teal);padding:80px 6%;text-align:center}
    .cta-strip .section-label{color:rgba(255,255,255,0.65)}
    .cta-strip .section-title{color:#fff;margin-bottom:12px}
    .cta-strip p{color:rgba(255,255,255,0.75);margin-bottom:32px;font-size:1rem;max-width:460px;margin-left:auto;margin-right:auto}

    /* ── ABOUT PHOTO GRID ── */
    .about-photos{display:grid;grid-template-columns:2fr 1fr;grid-template-rows:1fr 1fr;gap:10px;height:460px}
    .about-photos .ap-main{grid-row:1/3;border-radius:14px;overflow:hidden;border:1px solid var(--hairline)}
    .about-photos .ap-side{border-radius:14px;overflow:hidden;border:1px solid var(--hairline)}
    .about-photos img{width:100%;height:100%;object-fit:cover}

    /* ── FOOTER (light cloud background) ── */
    footer{background:var(--cloud);color:var(--ash);padding:56px 6% 32px;border-top:1px solid var(--hairline)}
    .footer-inner{display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:48px;padding-bottom:40px;border-bottom:1px solid var(--hairline);margin-bottom:28px}
    .footer-logo{font-size:1.1rem;font-weight:700;color:var(--ink);margin-bottom:12px;letter-spacing:-0.3px}
    .footer-logo em{font-style:normal;color:var(--teal)}
    .footer-desc{font-size:0.875rem;line-height:1.7;max-width:260px;color:var(--ash)}
    .footer-col h4{color:var(--ink);font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px}
    .footer-col ul{list-style:none;display:flex;flex-direction:column;gap:8px}
    .footer-col ul li a,.footer-col ul li span{font-size:0.875rem;color:var(--ash);transition:color 0.2s;text-decoration:none;font-weight:500}
    .footer-col ul li a:hover{color:var(--ink)}
    .footer-bottom{display:flex;justify-content:space-between;font-size:0.78rem;flex-wrap:wrap;gap:8px;color:var(--stone)}

    /* ── ANIMATIONS ── */
    .fade-up{opacity:0;transform:translateY(20px);transition:opacity 0.5s ease,transform 0.5s ease}
    .fade-up.visible{opacity:1;transform:translateY(0)}

    /* ── RESPONSIVE ── */
    @media(max-width:1024px){
      .nav-links,.nav-cta{display:none}
      .hamburger{display:flex}
    }
    @media(max-width:900px){
      .hero{grid-template-columns:1fr;min-height:auto;padding:100px 5% 60px}
      .hero-img-col{display:none}
      .steps-grid::before{display:none}
      .steps-grid{grid-template-columns:1fr;gap:36px}
      .split{grid-template-columns:1fr}
      .split-img{max-height:280px}
      .split.reverse .split-img{order:0}
      .pricing-grid{grid-template-columns:1fr}
      .info-strip{grid-template-columns:1fr 1fr}
      .info-block{border-right:none;border-bottom:1px solid var(--hairline)}
      .info-block:nth-child(even){border-right:none}
      .info-block:last-child{border-bottom:none}
      .about-photos{grid-template-columns:1fr;height:auto}
      .about-photos .ap-main{grid-row:auto;height:280px}
      .about-photos .ap-side{height:160px}
      .footer-inner{grid-template-columns:1fr 1fr}
    }
    @media(max-width:600px){
      section{padding:56px 5%}
      .hero{padding:90px 5% 52px}
      .info-strip{grid-template-columns:1fr}
      .info-block{border-bottom:1px solid var(--hairline)}
      .info-block:last-child{border-bottom:none}
      .footer-inner{grid-template-columns:1fr}
      .cards-grid{grid-template-columns:1fr}
      .cta-strip{padding:56px 5%}
      .photo-banner-content{padding:60px 5%}
    }

  </style>
  {%- block head %}{% endblock %}
</head>
<body>

{% include "nav.njk" %}

{% block content %}{% endblock %}

{% include "footer.njk" %}

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i * 70);
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  function toggleNav() {
    const menu = document.getElementById('mobileMenu');
    const burger = document.getElementById('hamburger');
    menu.classList.toggle('open');
    burger.classList.toggle('open');
  }
</script>
{%- block scripts %}{% endblock %}
</body>
</html>
